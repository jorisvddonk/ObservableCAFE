{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["*.ts", "agents/**/*.ts", "lib/**/*.ts", "tools/**/*.ts", "evaluators/**/*.ts", "examples/**/*.ts"]
}